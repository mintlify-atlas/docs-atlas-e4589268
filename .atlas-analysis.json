  "keyFeatures": [
    "Asset inventory management with detailed tracking of equipment and maintenance history",
    "Oil sample analysis with wear metals, contaminants, particle counts, and viscosity measurements",
    "Alarm monitoring system with acknowledgment workflow and linked recommendations",
    "Maintenance recommendations with severity levels and attachment support",
    "Root Cause Analysis (RCA) tool with 5 Whys, Logic Tree, and Fishbone diagram templates",
    "Multi-organization and multi-site support with role-based access control",
    "Dashboard analytics with trend analysis and forecasting for assets, alarms, and recommendations",
    "Sampling point and route management for systematic oil analysis collection"
  ],
  "publicApiSurface": [
    "Server Actions: createAsset, updateAsset, deleteAsset, getAssets",
    "Server Actions: createSample, updateSample, getSamples, getSampleHistory",
    "Server Actions: getAlarms, acknowledgeAlarm, linkAlarmToRecommendation",
    "Server Actions: createRecommendation, updateRecommendation, getRecommendations",
    "Server Actions: createOrganization, updateOrganization, getOrganizations",
    "Server Actions: createSite, updateSite, getSites",
    "Server Actions: createDepartment, updateDepartment, getDepartments",
    "Server Actions: login, register, resetPassword, verifyOtp",
    "Types: Asset, Sample, Alarm, Recommendation, RcaRecord",
    "Hooks: useContentGuard, useDebouncedState, useUrlState, usePresignedUrl",
    "Components: Button, Input, Select, Table, Modal, ConfirmDialog",
    "Components: AreaChart, BarChart, PieChart, SeverityCard, StatusBadge",
    "RCA Components: 5 Whys editor, Logic Tree builder, Fishbone diagram"
  ]
